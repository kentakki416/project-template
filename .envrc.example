#!/usr/bin/env bash
# .envrc.example — 別プロジェクトを並行起動する場合の参考設定。
#
# このプロジェクト (project-template) のデフォルトは 3000 番台。
# 別のプロジェクト (例: project-A) を同時に立ち上げると衝突するので、
# そちら側の .envrc を以下のような 4000 番台にずらすと共存できる。
#
# 想定運用:
#   project-template/  → 3000 番台（コミット済みの .envrc をそのまま）
#   project-A/         → 4000 番台（このファイルを参考に .envrc を書く）
#   project-B/         → 5000 番台
#
# ============================================================
# 例: 4000 番台に寄せる場合（project-A 側の .envrc）
# ============================================================
#
# export PORT_WEB=4000
# export PORT_ADMIN=4030
# export PORT_API=8180
# export POSTGRES_PORT=5433
# export REDIS_PORT=6380
#
# ============================================================
# 例: 5000 番台に寄せる場合（project-B 側の .envrc）
# ============================================================
#
# export PORT_WEB=5000
# export PORT_ADMIN=5030
# export PORT_API=8280
# export POSTGRES_PORT=5434
# export REDIS_PORT=6381
