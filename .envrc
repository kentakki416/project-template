#!/usr/bin/env bash
# direnv config — auto-loaded on `cd` into this directory.
#
# 複数プロジェクトをローカルで並行開発する際のポート衝突を避けるため、
# このプロジェクトで使うポート番号をすべてここで宣言する。
#
# このファイルはコミットする。別プロジェクトを並行起動する場合は、
# そちらの .envrc で 4000 / 5000 番台などにずらす。
#
# 初回 / 内容変更時は `direnv allow` の実行が必要。

# ============================================================
# このプロジェクトのポート帯
# ============================================================

# Next.js / Express
export PORT_WEB=3000    # apps/web
export PORT_ADMIN=3030  # apps/admin
export PORT_API=8080    # apps/api

# Postgres / Redis (docker-compose のホスト側ポート)
export POSTGRES_PORT=5432
export REDIS_PORT=6379
